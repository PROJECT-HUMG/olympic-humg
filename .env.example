# ===========================================================
# Environment variables for local development
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ===========================================================

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=olympic_humg_dev
DB_USERNAME=olympic_humg
DB_PASSWORD=olympic_secret

# ---- JWT ----
# Must be at least 32 characters for HS256
JWT_SECRET_KEY=this-is-a-super-secret-key-for-dev-only-32chars!!
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_MINUTES=10080

# ---- OAuth2 (optional for dev) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Client ----
OLYMPIC_CLIENT_BASE_URL=http://localhost:3000

# ---- Cookie ----
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# ---- Server ----
SERVER_PORT=8080
