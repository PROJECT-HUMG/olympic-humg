# ===========================================================
# Environment variables for local development
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ===========================================================

# ---- Database ----
POSTGRES_DB=olympic_humg_dev
POSTGRES_USER=olympic_humg
POSTGRES_PASSWORD=olympic_secret

# ---- API ----
API_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# DB_URL override (docker-compose sets this automatically)
# For local mvn run: DB_URL=jdbc:postgresql://localhost:5432/olympic_humg_dev

# ---- JWT ----
# Must be at least 32 characters for HS256
JWT_SECRET_KEY=dev-secret-key-with-at-least-32-bytes-long

# ---- OAuth2 (optional for dev) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Client ----
WEB_BASE_URL=http://localhost:3000

# ---- JVM ----
JAVA_TOOL_OPTIONS=
